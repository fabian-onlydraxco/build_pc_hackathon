# Copy this file to server/.env — server/.env is gitignored and never leaves
# your machine. With a key set, Glyde runs on live AI; without one, it runs on
# the built-in deterministic mock provider (full demo works, zero cost).

# Option A — OpenRouter (any model on openrouter.ai; pricing fetched live at boot)
# The default is a FREE model — works without loading credits.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Option B — Anthropic (used if no OpenRouter key is set)
ANTHROPIC_API_KEY=

# Optional overrides
# LLM_PROVIDER=openrouter | claude | mock   (default: auto by available key)
# ESTIMATED_CALL_USD=0.005                  (envelope-reservation estimate)
# PORT=5171
